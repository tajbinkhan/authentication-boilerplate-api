# Database Configuration
# The PostgreSQL connection URI. Example: postgres://user:password@localhost:5544/db
DATABASE_URL="postgres://boilerplate:boilerplate@localhost:5544/boilerplate"

# Application Configuration
# Port on which the NestJS server will listen
PORT=3000
# Node Environment (development or production)
NODE_ENV="development"

# Security & Secrets Configuration
# Secret key used for signing authentication tokens/JWTs
AUTH_SECRET="change-this-to-a-secure-random-key"
# Secret key used for signing CSRF tokens
CSRF_SECRET="change-this-to-a-secure-random-key"
# AES Encryption secret key (must be a secure 32-character key for AES-256)
CRYPTO_SECRET="change-this-to-a-secure-32-char"

# Cookie Configuration
# The domain scope for authentication cookies (e.g. localhost or yourdomain.com)
COOKIE_DOMAIN=""
# SameSite cookie attribute (lax, strict, or none)
COOKIE_SAME_SITE="lax"
# Whether cookies require HTTPS (set to true in production)
COOKIE_SECURE="false"

# CORS & Routing Configuration
# Allowed CORS origin URLs (comma-separated list)
ORIGIN_URL="http://localhost:5173"
# The public URL of the backend API
API_URL="http://localhost:3000"
# The public URL of the frontend application
APP_URL="http://localhost:5173"

# Google Integration (Optional for Google OAuth Login)
# Enable or disable Google login feature flag (true/false)
GOOGLE_LOGIN_ENABLED="false"
# Obtain this from Google Cloud Console under APIs & Services > Credentials
GOOGLE_CLIENT_ID=""

# Cloudinary Configuration (Optional for Profile/Media Image Uploads)
# Enable or disable Cloudinary uploads feature flag (true/false)
CLOUDINARY_ENABLED="false"
# Obtain these from your Cloudinary Dashboard settings
CLOUDINARY_CLOUD_NAME=""
CLOUDINARY_API_KEY=""
CLOUDINARY_API_SECRET=""

# Brevo (formerly Sendinblue) Configuration (Optional for Emails/Magic Links)
# Enable or disable Brevo email sending feature flag (true/false)
BREVO_ENABLED="false"
# Obtain this from Brevo SMTP & API settings
BREVO_API_KEY=""
# Email address displayed as the sender
BREVO_SENDER_EMAIL="noreply@yourdomain.com"
# Name displayed as the sender
BREVO_SENDER_NAME="Boilerplate Auth"

# Postgres Docker Configuration (Only used by docker-compose for local development)
POSTGRES_USER="boilerplate"
POSTGRES_PASSWORD="boilerplate"
POSTGRES_DB="boilerplate"
POSTGRES_PORT="5544"
