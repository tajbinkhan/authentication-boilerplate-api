# Database Configuration
# The PostgreSQL connection URI. Example: postgres://user:password@localhost:5544/db
DATABASE_URL="postgres://boilerplate:boilerplate@localhost:5544/boilerplate"

# Application Configuration
# Port on which the NestJS server will listen
PORT=3000
# Node Environment (development or production)
NODE_ENV="development"

# Security & Secrets Configuration
# Secret key used for signing authentication tokens/JWTs
AUTH_SECRET="change-this-to-a-secure-random-key"
# Secret key used for signing CSRF tokens
CSRF_SECRET="change-this-to-a-secure-random-key"
# AES Encryption secret key (must be a secure 32-character key for AES-256)
CRYPTO_SECRET="change-this-to-a-secure-32-char"

# Cookie Configuration
# The domain scope for authentication cookies (e.g. localhost or yourdomain.com)
COOKIE_DOMAIN=""
# SameSite cookie attribute (lax, strict, or none)
COOKIE_SAME_SITE="lax"
# Whether cookies require HTTPS (set to true in production)
COOKIE_SECURE="false"

# CORS & Routing Configuration
# Allowed CORS origin URLs (comma-separated list)
ORIGIN_URL="http://localhost:5173"
# The public URL of the backend API
API_URL="http://localhost:3000"
# The public URL of the frontend application
APP_URL="http://localhost:5173"

# Google Integration (Optional for Google OAuth Login)
# Enable or disable Google login feature flag (true/false)
GOOGLE_LOGIN_ENABLED="false"
# Obtain this from Google Cloud Console under APIs & Services > Credentials
GOOGLE_CLIENT_ID=""

# Cloudinary Configuration (Optional for Profile/Media Image Uploads)
# Enable or disable Cloudinary uploads feature flag (true/false)
CLOUDINARY_ENABLED="false"
# Obtain these from your Cloudinary Dashboard settings
CLOUDINARY_CLOUD_NAME=""
CLOUDINARY_API_KEY=""
CLOUDINARY_API_SECRET=""

# Email Configuration
# SMTP providers (Brevo, Resend, Nodemailer, AWS SES) are now configured via the
# SMTP Providers API/dashboard at runtime. No env vars are required for email.
# See docs/api/smtp.md for details.

# Postgres Docker Configuration (Only used by docker-compose for local development)
POSTGRES_USER="boilerplate"
POSTGRES_PASSWORD="boilerplate"
POSTGRES_DB="boilerplate"
POSTGRES_PORT="5544"

# Health Check Configuration (Optional — defaults shown)
# Memory heap limit in megabytes for the health check endpoint
HEALTH_HEAP_LIMIT_MB="150"
# Memory RSS limit in megabytes for the health check endpoint
HEALTH_RSS_LIMIT_MB="300"

# Security & Cache Store Configuration
# Storage backend for rate limiting, brute-force tracking, and security state.
# Options: memory (default, single-instance only), postgres (multi-instance, no extra deps), redis (distributed)
CACHE_STORE="memory"

# Redis connection URL — only required when CACHE_STORE=redis
# Example: redis://localhost:6379 or redis://user:pass@host:6379/0
REDIS_URL=""

# Rate limiting: time window in seconds for IP-based rate limiting
RATE_LIMIT_TTL_SECONDS=60
# Rate limiting: maximum requests per IP within the time window
RATE_LIMIT_MAX_REQUESTS=100

# Brute-force login protection: maximum failed login attempts before lockout
LOGIN_MAX_FAILED_ATTEMPTS=5
# Brute-force login protection: lockout duration in minutes after exceeding max attempts
LOGIN_LOCKOUT_MINUTES=15

# Password policy: minimum length (existing rules also require uppercase, lowercase, number, special char)
PASSWORD_MIN_LENGTH=8

# Security headers (Helmet): set to "false" to disable Helmet middleware
HELMET_ENABLED="true"

# Content Security Policy: optional custom CSP override. When empty, environment-aware defaults are used.
CSP_POLICY=""
