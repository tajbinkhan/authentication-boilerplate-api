{
	"name": "boilerplate-api",
	"version": "0.0.1",
	"description": "Boilerplate API for NestJS with Drizzle ORM and PostgreSQL",
	"author": "Tajbin Khan Evan",
	"private": true,
	"license": "MIT",
	"scripts": {
		"prebuild": "node update-schema.mjs",
		"predev": "node update-schema.mjs",
		"predb:studio": "node update-schema.mjs",
		"predb:generate": "node update-schema.mjs",
		"predb:migrate": "node update-schema.mjs",
		"predb:push": "node update-schema.mjs",
		"predb:clear": "node update-schema.mjs",
		"build": "nest build",
		"format": "prettier --write .",
		"start": "nest start",
		"dev": "nest start --watch",
		"debug": "nest start --debug --watch",
		"prod": "cross-env NODE_ENV=production node dist/src/main",
		"lint": "eslint \"{src,apps,libs}/**/*.ts\" --fix",
		"db:studio": "drizzle-kit studio",
		"db:generate": "drizzle-kit generate",
		"db:migrate": "drizzle-kit migrate",
		"db:push": "drizzle-kit push",
		"db:clear": "ts-node src/core/database/clean.ts",
		"db:seed": "ts-node src/core/database/seed.ts"
	},
	"dependencies": {
		"@aws-sdk/client-ses": "^3.1053.0",
		"@getbrevo/brevo": "^5.0.4",
		"@nestjs/common": "^11.1.23",
		"@nestjs/config": "^4.0.4",
		"@nestjs/core": "^11.1.23",
		"@nestjs/jwt": "^11.0.2",
		"@nestjs/passport": "^11.0.5",
		"@nestjs/platform-express": "^11.1.23",
		"@nestjs/terminus": "^11.1.1",
		"@nestjs/throttler": "^6.5.0",
		"@otplib/core": "13.4.0",
		"@otplib/plugin-base32-scure": "13.4.0",
		"@otplib/totp": "13.4.0",
		"@otplib/uri": "13.4.0",
		"@trivago/prettier-plugin-sort-imports": "^6.0.2",
		"@types/cookie-parser": "^1.4.10",
		"@types/pg": "^8.20.0",
		"axios": "^1.16.1",
		"bcryptjs": "^3.0.3",
		"cloudinary": "^2.10.0",
		"cookie-parser": "^1.4.7",
		"csrf-csrf": "^4.0.3",
		"dotenv": "^17.4.2",
		"drizzle-kit": "^0.31.10",
		"drizzle-orm": "^0.45.2",
		"eslint-plugin-unused-imports": "^4.4.1",
		"google-auth-library": "^10.6.2",
		"handlebars": "^4.7.9",
		"helmet": "^8.2.0",
		"ioredis": "^5.10.1",
		"libphonenumber-js": "^1.13.2",
		"multer": "^2.1.1",
		"nodemailer": "^8.0.8",
		"passport": "^0.7.0",
		"passport-jwt": "^4.0.1",
		"pg": "^8.21.0",
		"pino": "^10.3.1",
		"pino-http": "^11.0.0",
		"pino-pretty": "^13.1.3",
		"qrcode": "^1.5.4",
		"reflect-metadata": "^0.2.2",
		"resend": "^6.12.3",
		"rrule": "^2.8.1",
		"rxjs": "^7.8.2",
		"ua-parser-js": "^2.0.10",
		"zod": "^4.4.3"
	},
	"devDependencies": {
		"@eslint/eslintrc": "^3.3.5",
		"@eslint/js": "^10.0.1",
		"@nestjs/cli": "^11.0.21",
		"@nestjs/schematics": "^11.1.0",
		"@swc/cli": "^0.8.1",
		"@swc/core": "^1.15.33",
		"@types/express": "^5.0.6",
		"@types/multer": "^2.1.0",
		"@types/node": "^25.9.1",
		"@types/nodemailer": "^8.0.0",
		"@types/passport-jwt": "^4.0.1",
		"@types/qrcode": "^1.5.6",
		"eslint": "^10.4.0",
		"eslint-config-prettier": "^10.1.8",
		"eslint-plugin-prettier": "^5.5.5",
		"globals": "^17.6.0",
		"prettier": "^3.8.3",
		"source-map-support": "^0.5.21",
		"ts-loader": "^9.5.7",
		"ts-node": "^10.9.2",
		"tsconfig-paths": "^4.2.0",
		"typescript": "^6.0.3",
		"typescript-eslint": "^8.59.4"
	}
}
